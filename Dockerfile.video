# adarai SKY video worker , serverless pour les workflows Sky (NSFW studio).
# Environnement FIGÉ : chaque custom node est clone au commit EXACT du pod video
# qui marche (snapshot 2026-07-03). AUCUN modèle dans l'image : les modèles vivent sur le
# network volume RunPod (monte sur /runpod-volume, layout /workspace du pod), vus via
# extra_model_paths.yaml. Ne JAMAIS passer un node en branche flottante : c'est
# precisement ce qui casse les pods du vendeur a chaque update.
#
# Base bumped 5.7.1 -> 5.8.6 (2026-07-08): 5.7.1 predates worker-comfyui PR #197
# (shipped 5.8.3), which fixed exactly the "ComfyUI server not reachable after
# multiple retries" / "WebSocket... unreachable during reconnect" symptom our
# Wan/SeedVR2 jobs were hitting mid-run. Pre-197, when ComfyUI's process dies for
# ANY reason (OOM, CUDA fault, dependency crash), the handler silently polls a
# dead server for its retry budget before returning that ambiguous error; 197
# adds a PID-liveness check so a dead ComfyUI fails IMMEDIATELY with an explicit
# "ComfyUI process has exited" message instead. This doesn't fix whatever kills
# ComfyUI (still under investigation — leading hypothesis: VRAM exhaustion on
# Wan2.1-14B native-attention sampling at our above-480p resolutions, worse on
# the 32GB RTX 5090 than the 80GB A100 variants in this endpoint's GPU pool),
# but turns the next crash into a diagnosable signal instead of noise.
# -cuda12.8.1 variant matches the torch 2.8.0+cu128 install below.
FROM runpod/worker-comfyui:5.8.6-base-cuda12.8.1

# SageAttention (installed below, used by every Wan video graph) JIT-compiles its
# CUDA kernels through Triton at runtime, which needs a C compiler. The slim base
# image has none, so sampling died with "Failed to find C compiler" after ~90s of
# GPU time on EVERY Wan video (the manual pod worked because its devel base ships
# gcc — the classic works-on-pod, fails-on-serverless gap). Install the toolchain
# and point Triton at it.
RUN apt-get update && apt-get install -y --no-install-recommends build-essential \
 && rm -rf /var/lib/apt/lists/*
ENV CC=gcc CXX=g++

# Pin ComfyUI to the EXACT version the manual video pod runs (v0.27.0), same as
# Dockerfile.image. The v5 Wan SCAIL pipeline (WanSCAILToVideo, SAM3_VideoTrack,
# SCAIL2ColoredMask, ColorTransfer, ComfyMathExpression, ResizeImageMaskNode,
# BatchImagesNode…) are CORE nodes that only exist in ComfyUI >= 0.27; the
# worker-comfyui base ships older, so the serverless worker was missing them
# (validated live against the pod). Torch is 2.8+cu128 (installed below), so
# v0.27.0's deps line up.
RUN cd /comfyui && git fetch --depth 1 origin refs/tags/v0.27.0:refs/tags/v0.27.0 \
 && git checkout -f v0.27.0 \
 && pip install --no-cache-dir -r requirements.txt || echo "warn: comfyui pin v0.27.0"

WORKDIR /comfyui/custom_nodes

RUN git clone https://github.com/M1kep/ComfyLiterals.git 'ComfyLiterals' && git -C 'ComfyLiterals' checkout bdddb08ca82d90d75d97b1d437a652e0284a32ac && rm -rf 'ComfyLiterals/.git'
RUN git clone https://github.com/evanspearman/ComfyMath.git 'ComfyMath' && git -C 'ComfyMath' checkout c01177221c31b8e5fbc062778fc8254aeb541638 && rm -rf 'ComfyMath/.git'
RUN git clone https://github.com/pythongosssss/ComfyUI-Custom-Scripts.git 'ComfyUI-Custom-Scripts' && git -C 'ComfyUI-Custom-Scripts' checkout 609f3afaa74b2f88ef9ce8d939626065e3247469 && rm -rf 'ComfyUI-Custom-Scripts/.git'
RUN git clone https://github.com/AIFSH/ComfyUI-DiffSynth-Studio.git 'ComfyUI-DiffSynth-Studio' && git -C 'ComfyUI-DiffSynth-Studio' checkout 91d0a6bd9efa6a1d4a0b880984e21fe66acf4eb0 && rm -rf 'ComfyUI-DiffSynth-Studio/.git'
RUN git clone https://github.com/LeonQ8/ComfyUI-Dynamic-Lora-Scheduler.git 'ComfyUI-Dynamic-Lora-Scheduler' && git -C 'ComfyUI-Dynamic-Lora-Scheduler' checkout b5a796bb8c6995129283c3e216aae7fc5e889f2a && rm -rf 'ComfyUI-Dynamic-Lora-Scheduler/.git'
RUN git clone https://github.com/yolain/ComfyUI-Easy-Use.git 'ComfyUI-Easy-Use' && git -C 'ComfyUI-Easy-Use' checkout 54d080bf6a4f52da287e984f305243c10db097f5 && rm -rf 'ComfyUI-Easy-Use/.git'
RUN git clone https://github.com/Fannovel16/ComfyUI-Frame-Interpolation.git 'ComfyUI-Frame-Interpolation' && git -C 'ComfyUI-Frame-Interpolation' checkout 26545cc2dd95bc3d27f056016300673bdeee78f5 && rm -rf 'ComfyUI-Frame-Interpolation/.git'
RUN git clone https://github.com/kijai/ComfyUI-GIMM-VFI.git 'ComfyUI-GIMM-VFI' && git -C 'ComfyUI-GIMM-VFI' checkout 4c9a3123762af85e7c796e41737da0b70c75d72d && rm -rf 'ComfyUI-GIMM-VFI/.git'
RUN git clone https://github.com/ltdrdata/ComfyUI-Impact-Pack.git 'ComfyUI-Impact-Pack' && git -C 'ComfyUI-Impact-Pack' checkout 429d0159ad429e64d2b3916e6e7be9c22d025c3c && rm -rf 'ComfyUI-Impact-Pack/.git'
RUN git clone https://github.com/lquesada/ComfyUI-Inpaint-CropAndStitch.git 'ComfyUI-Inpaint-CropAndStitch' && git -C 'ComfyUI-Inpaint-CropAndStitch' checkout 3617559bcb9d15ff60b24c6800701402eb2cd478 && rm -rf 'ComfyUI-Inpaint-CropAndStitch/.git'
RUN git clone https://github.com/kijai/ComfyUI-KJNodes.git 'ComfyUI-KJNodes' && git -C 'ComfyUI-KJNodes' checkout e27a505b3ba6ce42687fe00500deda103d9d6071 && rm -rf 'ComfyUI-KJNodes/.git'
RUN git clone https://github.com/Lightricks/ComfyUI-LTXVideo.git 'ComfyUI-LTXVideo' && git -C 'ComfyUI-LTXVideo' checkout aceeae9635f6d493f2893ba3c411a1c36031788a && rm -rf 'ComfyUI-LTXVideo/.git'
RUN git clone https://github.com/kijai/ComfyUI-NativeLooping_testing.git 'ComfyUI-NativeLooping_testing' && git -C 'ComfyUI-NativeLooping_testing' checkout 82fff6130ec00a69907feb4d4023ef24a57f0e7a && rm -rf 'ComfyUI-NativeLooping_testing/.git'
RUN git clone https://github.com/omar92/ComfyUI-QualityOfLifeSuit_Omar92.git 'ComfyUI-QualityOfLifeSuit_Omar92' && git -C 'ComfyUI-QualityOfLifeSuit_Omar92' checkout 793b6d27e9e501e56aeb630cb502462bc0af9fed && rm -rf 'ComfyUI-QualityOfLifeSuit_Omar92/.git'
RUN git clone https://github.com/1038lab/ComfyUI-QwenVL.git 'ComfyUI-QwenVL' && git -C 'ComfyUI-QwenVL' checkout fcd1ada87a28f922cb887f779db32429f78a022c && rm -rf 'ComfyUI-QwenVL/.git'
RUN git clone https://github.com/1038lab/ComfyUI-RMBG.git 'ComfyUI-RMBG' && git -C 'ComfyUI-RMBG' checkout d7402513f23f58db7d56754b02a4f51a148b4941 && rm -rf 'ComfyUI-RMBG/.git'
RUN git clone https://github.com/numz/ComfyUI-SeedVR2_VideoUpscaler.git 'ComfyUI-SeedVR2_VideoUpscaler' && git -C 'ComfyUI-SeedVR2_VideoUpscaler' checkout 4490bd1f482e026674543386bb2a4d176da245b9 && rm -rf 'ComfyUI-SeedVR2_VideoUpscaler/.git'
RUN git clone https://github.com/Kosinkadink/ComfyUI-VideoHelperSuite.git 'ComfyUI-VideoHelperSuite' && git -C 'ComfyUI-VideoHelperSuite' checkout 4ee72c065db22c9d96c2427954dc69e7b908444b && rm -rf 'ComfyUI-VideoHelperSuite/.git'
RUN git clone https://github.com/kijai/ComfyUI-WanAnimatePreprocess.git 'ComfyUI-WanAnimatePreprocess' && git -C 'ComfyUI-WanAnimatePreprocess' checkout 0e0b6a2a555625acf4d4aefb780e27d06937132f && rm -rf 'ComfyUI-WanAnimatePreprocess/.git'
RUN git clone https://github.com/kijai/ComfyUI-WanVideoWrapper.git 'ComfyUI-WanVideoWrapper' && git -C 'ComfyUI-WanVideoWrapper' checkout 088128b224242e110d3906c6750e9a3a348a659b && rm -rf 'ComfyUI-WanVideoWrapper/.git'
RUN git clone https://github.com/kijai/ComfyUI-segment-anything-2.git 'ComfyUI-segment-anything-2' && git -C 'ComfyUI-segment-anything-2' checkout 0c35fff5f382803e2310103357b5e985f5437f32 && rm -rf 'ComfyUI-segment-anything-2/.git'
# comfyui_controlnet_aux : fournit DWPreprocessor (detection de pose DWPose) utilise
# par le workflow Wan Animate (motion-control). Manquait ici alors que les autres
# nodes Wan Animate (WanVideoWrapper AnimateEmbeds, WanAnimatePreprocess, SAM2) sont
# deja presents. Meme pack que l'ancien worker adarai-wananimate (config prouvee).
RUN git clone https://github.com/Fannovel16/comfyui_controlnet_aux.git 'comfyui_controlnet_aux' && git -C 'comfyui_controlnet_aux' checkout e8b689a513c3e6b63edc44066560ca5919c0576e && rm -rf 'comfyui_controlnet_aux/.git'
RUN git clone https://github.com/Suzie1/ComfyUI_Comfyroll_CustomNodes.git 'ComfyUI_Comfyroll_CustomNodes' && git -C 'ComfyUI_Comfyroll_CustomNodes' checkout d78b780ae43fcf8c6b7c6505e6ffb4584281ceca && rm -rf 'ComfyUI_Comfyroll_CustomNodes/.git'
RUN git clone https://github.com/filliptm/ComfyUI_Fill-Nodes.git 'ComfyUI_Fill-Nodes' && git -C 'ComfyUI_Fill-Nodes' checkout d2453f02a1b8a03570e9855af8f5796fa40ea7d9 && rm -rf 'ComfyUI_Fill-Nodes/.git'
RUN git clone https://github.com/chflame163/ComfyUI_LayerStyle.git 'ComfyUI_LayerStyle' && git -C 'ComfyUI_LayerStyle' checkout d94bef1ee5ed3656f5ff1bb2830a4ffd94f40935 && rm -rf 'ComfyUI_LayerStyle/.git'
RUN git clone https://github.com/IuvenisSapiens/ComfyUI_Qwen3-VL-Instruct.git 'ComfyUI_Qwen3-VL-Instruct' && git -C 'ComfyUI_Qwen3-VL-Instruct' checkout 70cc35edacfd5979cbe7a15caf56bd2f715bc3b5 && rm -rf 'ComfyUI_Qwen3-VL-Instruct/.git'
RUN git clone https://github.com/smthemex/ComfyUI_SparkVSR_SM.git 'ComfyUI_SparkVSR_SM' && git -C 'ComfyUI_SparkVSR_SM' checkout 30f3378e5ddc172b85c3d8776a02e808f7694c28 && rm -rf 'ComfyUI_SparkVSR_SM/.git'
RUN git clone https://github.com/aining2022/ComfyUI_Swwan.git 'ComfyUI_Swwan' && git -C 'ComfyUI_Swwan' checkout 9c683a7287989661d16903d7b9c13a382f6ce804 && rm -rf 'ComfyUI_Swwan/.git'
RUN git clone https://github.com/cubiq/ComfyUI_essentials.git 'ComfyUI_essentials' && git -C 'ComfyUI_essentials' checkout 9d9f4bedfc9f0321c19faf71855e228c93bd0dc9 && rm -rf 'ComfyUI_essentials/.git'
RUN git clone https://github.com/TTPlanetPig/Comfyui_TTP_Toolset.git 'Comfyui_TTP_Toolset' && git -C 'Comfyui_TTP_Toolset' checkout 981ae4020e7ae103b913f004e51653a3483003f4 && rm -rf 'Comfyui_TTP_Toolset/.git'
RUN git clone https://github.com/Pirog17000/Pirogs-Nodes.git 'Pirogs-Nodes' && git -C 'Pirogs-Nodes' checkout 7ac589ef47f970bf6caf7a54f79ddba4c3d90077 && rm -rf 'Pirogs-Nodes/.git'
RUN git clone https://github.com/ashtar1984/comfyui-find-perfect-resolution.git 'comfyui-find-perfect-resolution' && git -C 'comfyui-find-perfect-resolution' checkout b8ee6c1872e796329bffbcbf53a5207aaf964bdb && rm -rf 'comfyui-find-perfect-resolution/.git'
RUN git clone https://github.com/MixLabPro/comfyui-mixlab-nodes.git 'comfyui-mixlab-nodes' && git -C 'comfyui-mixlab-nodes' checkout c5392aa23762a440834c056c3e22cf99ccf52703 && rm -rf 'comfyui-mixlab-nodes/.git'
RUN git clone https://github.com/jamesWalker55/comfyui-various.git 'comfyui-various' && git -C 'comfyui-various' checkout 5bd85aaf7616878471469c4ec7e11bbd0cef3bf2 && rm -rf 'comfyui-various/.git'
RUN git clone https://github.com/YaserJaradeh/comfyui-yaser-nodes.git 'comfyui-yaser-nodes' && git -C 'comfyui-yaser-nodes' checkout 68225852a11e22e735631aa11ea065e82ea191d4 && rm -rf 'comfyui-yaser-nodes/.git'
RUN git clone https://github.com/BadCafeCode/masquerade-nodes-comfyui.git 'masquerade-nodes-comfyui' && git -C 'masquerade-nodes-comfyui' checkout 432cb4d146a391b387a0cd25ace824328b5b61cf && rm -rf 'masquerade-nodes-comfyui/.git'
RUN git clone https://github.com/rgthree/rgthree-comfy.git 'rgthree-comfy' && git -C 'rgthree-comfy' checkout 27b4f4cdcf3b127c29d5d8135ac1536ecbd4c383 && rm -rf 'rgthree-comfy/.git'
RUN git clone https://github.com/WASasquatch/was-node-suite-comfyui.git 'was-node-suite-comfyui' && git -C 'was-node-suite-comfyui' checkout ea935d1044ae5a26efa54ebeb18fe9020af49a45 && rm -rf 'was-node-suite-comfyui/.git'

# Deps python des nodes, en protegeant le stack CUDA/torch de la base (pattern
# eprouve sur adarai-wananimate) : on retire torch/xformers/numpy/onnxruntime des
# requirements avant install, best-effort pour ne pas rater le build sur un node.
RUN for d in */ ; do \
      d="${d%/}"; \
      if [ -f "$d/requirements.txt" ]; then \
        grep -ivE '^[[:space:]]*(torch|torchvision|torchaudio|xformers|numpy|onnxruntime|onnxruntime-gpu)([=<>!~ ]|$)' "$d/requirements.txt" > /tmp/req.txt 2>/dev/null || cp "$d/requirements.txt" /tmp/req.txt; \
        pip install --no-cache-dir -r /tmp/req.txt || echo "warn: deps $d"; \
      fi; \
    done
RUN pip install --no-cache-dir onnxruntime-gpu || pip install --no-cache-dir onnxruntime || echo "warn: onnxruntime"


# Modeles + caches sur le network volume (partages entre workers, zero re-download)
COPY extra_model_paths.yaml /comfyui/extra_model_paths.yaml
ENV HF_HOME=/runpod-volume/.cache/huggingface \
    TORCH_HOME=/runpod-volume/.cache/torch \
    COMFYUI_MODEL_PATH=/runpod-volume/ComfyUI/models \
    PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True \
    REFRESH_WORKER=true
# expandable_segments reduces allocator fragmentation (no tuning existed before
# 2026-07-08) — cheap margin against the same VRAM-exhaustion hypothesis above.
# REFRESH_WORKER restarts the pod after every job so a crash never leaves the
# next job on a worker with fragmented/leaked VRAM or a zombie ComfyUI process;
# costs a cold start per job (loses some flashboot benefit) in exchange for
# not letting one bad job take down several more silently.

WORKDIR /comfyui
# Torch ALIGNE SUR LES PODS DU VENDEUR : 2.8.0 cu128 (compatible RTX 5090 /
# RTX Pro 4500 Blackwell, les seuls GPU largement dispo dans EU-RO-1 ou vivent
# les network volumes). Le torch de la base worker-comfyui est plus vieux et ne
# demarre pas sur Blackwell (jobs bloques en THROTTLED/queue). Installe APRES les
# deps des nodes pour que rien ne le re-ecrase.
RUN pip install --no-cache-dir --upgrade --index-url https://download.pytorch.org/whl/cu128 torch==2.8.0 torchvision==0.23.0 torchaudio==2.8.0

# Le handler 5.7.1 code EN DUR l'attente de ComfyUI (500 x 50ms = 25s), pas d'env.
# Avec ~40 packs de nodes, ComfyUI met 1-3 min a demarrer -> chaque cold start
# echouait en "ComfyUI server not reachable". On patche la constante: 6000 x 100ms
# = 10 min de patience au premier boot (les boots suivants sont instantanes).
RUN f=$(find / -maxdepth 3 -name "handler.py" 2>/dev/null | head -1) && \
    sed -i 's/COMFY_API_AVAILABLE_MAX_RETRIES = 500/COMFY_API_AVAILABLE_MAX_RETRIES = 6000/; s/COMFY_API_AVAILABLE_INTERVAL_MS = 50/COMFY_API_AVAILABLE_INTERVAL_MS = 100/' "$f" && \
    grep -n "COMFY_API_AVAILABLE" "$f" | head -2

# libcuda runtime-symlink fix (see libcuda_fix.py for full rationale). Triton
# JIT-compiles a CUDA launcher stub at first call (SageAttention's Triton
# kernels, used by PathchSageAttentionKJ whenever sage_attention != "disabled").
# gcc's `-lcuda` needs an UNVERSIONED libcuda.so next to the driver-mounted
# libcuda.so.1 -- RunPod's container runtime only bind-mounts the real,
# versioned libcuda.so.1 once this container is scheduled onto a live GPU
# worker, so this can only be fixed at real container start, never at
# `docker build` (no GPU/driver exists then). Reuse the exact handler.py
# discovery already proven above (same file RunPod actually executes) and
# prepend the fix so it runs before ComfyUI/torch/Triton do anything.
# INERT while sage_attention stays "disabled" in every deployed graph: Triton
# is never invoked, so this code path is never exercised.
COPY libcuda_fix.py /opt/libcuda_fix.py
RUN f=$(find / -maxdepth 3 -name "handler.py" 2>/dev/null | head -1) && \
    cat /opt/libcuda_fix.py "$f" > /tmp/handler_patched.py && \
    mv /tmp/handler_patched.py "$f" && \
    echo "patched libcuda fix into: $f" && head -20 "$f"

# The handler.py prepend above only fixes handler.py's OWN process. ComfyUI
# (main.py) runs as a SEPARATE process started by this image's entrypoint --
# confirmed live 2026-07-08: the handler-side symlink+TRITON_LIBCUDA_PATH did
# NOT change gcc's actual -L flags on the next crash, meaning the fix never
# reached the process that actually runs Triton. `sitecustomize.py` is a
# Python stdlib convention: ANY file named exactly that on site-packages is
# auto-imported at interpreter startup for EVERY process using that Python
# install -- unlike prepending to one specific entry file, this reaches both
# handler.py AND ComfyUI's main.py since they share the same /opt/venv.
RUN python3 -c "import site; print(site.getsitepackages()[0])" > /tmp/sitepkgs.txt && \
    cp /opt/libcuda_fix.py "$(cat /tmp/sitepkgs.txt)/sitecustomize.py" && \
    echo "installed sitecustomize.py in: $(cat /tmp/sitepkgs.txt)"

# SageAttention (accelerateur d'attention utilise par les workflows Wan des pods).
RUN pip install --no-cache-dir sageattention || echo "warn: sageattention"

# Validation AU BUILD : importe tous les custom nodes et démarre ComfyUI en mode
# test CI (CPU). Un node qui crashe le serveur fait échouer le BUILD avec le log
# exact, au lieu d'un "ComfyUI not reachable" muet au runtime. Ça déclenche aussi
# le provisioning SAM3/pixi pendant le build (fini les cold starts interminables).
RUN cd /comfyui && python main.py --quick-test-for-ci --cpu
